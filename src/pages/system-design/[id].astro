---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('system-design');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<title>{post.data.title}</title>
	</head>
	<body class="bg-slate-900 text-slate-100 min-h-screen p-8 font-sans">
		<main class="max-w-3xl mx-auto">
			<a href={`${import.meta.env.BASE_URL}`} class="text-blue-400 hover:underline mb-8 inline-block">← Back to Portfolio</a>
			<article class="prose prose-invert lg:prose-xl max-w-none">
				<header class="mb-8">
					<h1 class="text-4xl font-extrabold mb-4">{post.data.title}</h1>
					<div class="flex gap-4 text-slate-400 text-sm">
						<time>{post.data.pubDate.toLocaleDateString()}</time>
						<span>•</span>
						<span class="font-semibold text-yellow-400">{post.data.complexity} Complexity</span>
					</div>
				</header>
				<div class="markdown-content">
					<Content />
				</div>
			</article>
		</main>
	</body>
</html>

<style is:global>
	.markdown-content h2 { @apply text-2xl font-bold mt-8 mb-4 text-blue-300; }
	.markdown-content h3 { @apply text-xl font-bold mt-6 mb-3 text-blue-200; }
	.markdown-content p { @apply mb-4 text-slate-300 leading-relaxed; }
	.markdown-content code { @apply bg-slate-800 px-1 rounded text-pink-400; }
	.markdown-content pre { @apply bg-slate-800 p-4 rounded-lg overflow-x-auto border border-slate-700 my-6; }
	.markdown-content pre code { @apply bg-transparent p-0 text-slate-100 text-sm; }
	.markdown-content ul { @apply list-disc ml-6 mb-4 text-slate-300; }
</style>
