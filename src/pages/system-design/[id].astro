---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('system-design');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | Sreejith`} description={post.data.description}>
	<main class="max-w-4xl mx-auto px-6 pt-32 pb-20">
		<a href={`${import.meta.env.BASE_URL}/`} class="group inline-flex items-center gap-2 text-slate-400 hover:text-white transition-colors mb-12 text-sm font-medium">
			<svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
			</svg>
			Back to Portfolio
		</a>

		<article class="glass-card p-8 md:p-12 overflow-hidden">
			<header class="mb-12 border-b border-white/5 pb-12">
				<div class="flex flex-wrap gap-4 items-center mb-6">
					<span class={`px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-tighter ${
						post.data.complexity === 'Easy' ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' :
						post.data.complexity === 'Medium' ? 'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20' :
						'bg-red-500/10 text-red-400 border border-red-500/20'
					}`}>
						{post.data.complexity} Complexity
					</span>
					<span class="text-slate-600">•</span>
					<time class="text-slate-400 text-sm font-medium">
						{post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
					</time>
				</div>
				<h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight text-white">
					{post.data.title}
				</h1>
				<p class="text-slate-400 text-lg md:text-xl leading-relaxed max-w-3xl">
					{post.data.description}
				</p>
			</header>

			<div class="markdown-content prose prose-invert prose-lg max-w-none prose-headings:text-white prose-a:text-blue-400 prose-code:text-emerald-400 prose-pre:bg-slate-950 prose-pre:border prose-pre:border-white/5">
				<Content />
			</div>

			<footer class="mt-16 pt-8 border-t border-white/5 flex flex-wrap gap-2">
				{post.data.tags.map(tag => (
					<span class="text-[10px] font-bold uppercase tracking-widest bg-slate-800 text-slate-400 px-4 py-1.5 rounded-full border border-white/5">
						#{tag}
					</span>
				))}
			</footer>
		</article>
	</main>
</Layout>

<style is:global>
	.markdown-content h2 { @apply text-2xl font-bold mt-12 mb-6 text-white border-b border-white/5 pb-2; }
	.markdown-content h3 { @apply text-xl font-bold mt-8 mb-4 text-blue-300; }
	.markdown-content p { @apply mb-6 text-slate-300 leading-relaxed; }
	.markdown-content ul { @apply list-disc ml-6 mb-8 text-slate-300 space-y-2; }
	.markdown-content li::marker { @apply text-blue-500; }
	.markdown-content pre { @apply my-8 rounded-2xl p-6 shadow-2xl; }
	.markdown-content blockquote { @apply border-l-4 border-blue-500 bg-blue-500/5 p-6 rounded-r-2xl italic text-slate-300 my-8; }
</style>
