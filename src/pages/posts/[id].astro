---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Filter to only show H2 and H3 in ToC
const tocHeadings = headings.filter(h => h.depth <= 3);
---

<Layout title={`${post.data.title} | Engineering Bytes`} description={post.data.description}>
	<main class="max-w-7xl mx-auto px-6 pt-32 pb-20">
		<div class="grid lg:grid-cols-[1fr_250px] gap-12 items-start">
			<!-- Main Content -->
			<div>
				<a href={`${import.meta.env.BASE_URL}/`} class="inline-flex items-center gap-2 text-slate-500 hover:text-white transition-colors mb-12 text-xs font-mono font-bold uppercase tracking-widest group">
					<svg class="w-3 h-3 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
					</svg>
					Back to Registry
				</a>

				<article>
					<header class="mb-12 border-b border-white/5 pb-12">
						<div class="flex items-center gap-4 mb-6">
							<span class="text-[10px] font-mono font-bold text-blue-500 bg-blue-500/10 px-2 py-0.5 rounded border border-blue-500/20 uppercase">
								{post.data.category}
							</span>
							<span class="text-slate-700 font-mono text-xs">//</span>
							<time class="text-slate-500 font-mono text-[10px] uppercase">
								{post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
							</time>
						</div>
						
						<h1 class="text-4xl md:text-5xl font-extrabold mb-8 text-white tracking-tight leading-tight">
							{post.data.title}
						</h1>

						<!-- TL;DR / Summary Box -->
						<div class="blueprint-card p-6 border-l-4 border-l-blue-500 bg-blue-500/[0.03]">
							<div class="flex items-center gap-2 mb-3">
								<svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
								<span class="text-[10px] font-mono font-bold text-blue-400 uppercase tracking-widest">TL;DR // Summary</span>
							</div>
							<p class="text-slate-300 text-sm leading-relaxed italic">
								{post.data.description}
							</p>
						</div>
					</header>

					<div class="markdown-content prose prose-invert prose-slate max-w-none 
						prose-headings:text-white prose-headings:font-bold prose-headings:tracking-tight
						prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline
						prose-strong:text-white prose-code:text-blue-300 prose-code:bg-blue-500/10 
						prose-code:px-1 prose-code:rounded prose-pre:bg-slate-950 prose-pre:border 
						prose-pre:border-white/5 prose-pre:rounded-xl">
						<Content />
					</div>

					<footer class="mt-20 pt-12 border-t border-white/5">
						<div class="flex flex-wrap gap-2">
							{post.data.tags.map(tag => (
								<span class="text-[9px] font-mono font-bold text-slate-500 border border-white/10 px-3 py-1 rounded-full uppercase">
									#{tag}
								</span>
							))}
						</div>
					</footer>
				</article>
			</div>

			<!-- Sticky Sidebar (ToC) -->
			<aside class="hidden lg:block sticky top-32">
				<div class="blueprint-card p-6">
					<h3 class="text-[10px] font-mono font-bold text-slate-500 uppercase tracking-widest mb-6 pb-2 border-b border-white/5">
						Technical Index
					</h3>
					<nav class="space-y-4">
						{tocHeadings.map(heading => (
							<a 
								href={`#${heading.slug}`} 
								class={`block text-xs font-mono transition-colors hover:text-blue-400 ${
									heading.depth === 2 ? 'text-slate-400 font-bold' : 'text-slate-500 pl-4'
								}`}
							>
								<span class="text-blue-500/40 mr-1 opacity-0 group-hover:opacity-100">#</span>
								{heading.text}
							</a>
						))}
					</nav>
					<div class="mt-8 pt-6 border-t border-white/5">
						<div class="flex items-center gap-2">
							<div class="w-1.5 h-1.5 rounded-full bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.5)]"></div>
							<span class="text-[9px] font-mono text-slate-500 uppercase">Reading Mode: Active</span>
						</div>
					</div>
				</div>
			</aside>
		</div>
	</main>
</Layout>

<style is:global>
	.markdown-content h2 { @apply text-2xl font-bold mt-16 mb-6 text-white border-b border-white/5 pb-2 scroll-mt-32; }
	.markdown-content h3 { @apply text-xl font-bold mt-10 mb-4 text-slate-100 scroll-mt-32; }
	.markdown-content p { @apply mb-6 text-slate-400 leading-relaxed; }
	.markdown-content ul { @apply list-disc ml-6 mb-8 text-slate-400 space-y-3; }
	.markdown-content li::marker { @apply text-blue-500; }
	.markdown-content pre { @apply my-8 p-6 shadow-xl !bg-[#010409]; }
	.markdown-content blockquote { @apply border-l-2 border-blue-500 bg-blue-500/5 p-6 rounded-r-xl italic text-slate-400 my-8; }
</style>
