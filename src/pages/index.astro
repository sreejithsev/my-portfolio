---
import { getCollection } from 'astro:content';

const posts = await getCollection('system-design');
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>My Portfolio | System Design & Java</title>
	</head>
	<body class="bg-slate-900 text-slate-100 min-h-screen p-8 font-sans">
		<main class="max-w-4xl mx-auto">
			<header class="mb-12 border-b border-slate-700 pb-8">
				<h1 class="text-4xl font-bold mb-2">Sreejith's Portfolio</h1>
				<p class="text-slate-400 text-lg">System Design, Java Architecture, and Scalability Case Studies</p>
			</header>

			<section>
				<h2 class="text-2xl font-semibold mb-6 text-blue-400">Latest System Design Posts</h2>
				<div class="grid gap-6">
					{posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()).map(post => (
						<article class="p-6 bg-slate-800 rounded-xl border border-slate-700 hover:border-blue-500 transition-colors shadow-lg">
							<div class="flex justify-between items-start mb-2">
								<h3 class="text-xl font-bold">
									<a href={`/my-portfolio/system-design/${post.id}`} class="hover:text-blue-400">
										{post.data.title}
									</a>
								</h3>
								<span class={`px-3 py-1 rounded-full text-xs font-bold ${
									post.data.complexity === 'Easy' ? 'bg-green-900 text-green-300' :
									post.data.complexity === 'Medium' ? 'bg-yellow-900 text-yellow-300' :
									'bg-red-900 text-red-300'
								}`}>
									{post.data.complexity}
								</span>
							</div>
							<p class="text-slate-400 mb-4">{post.data.description}</p>
							<div class="flex gap-2">
								{post.data.tags.map(tag => (
									<span class="text-xs bg-slate-700 px-2 py-1 rounded text-slate-300 border border-slate-600">
										#{tag}
									</span>
								))}
							</div>
						</article>
					))}
				</div>
			</section>
		</main>
	</body>
</html>
