---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = await getCollection('system-design');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const skills = [
	{ category: "Backend", items: ["Java 21+", "Spring Boot", "Node.js", "Microservices"] },
	{ category: "System Design", items: ["Scalability", "High Availability", "Event Driven", "Distributed Systems"] },
	{ category: "Infrastructure", items: ["AWS", "Docker", "Kubernetes", "CI/CD"] }
];
---

<Layout title="Sreejith | Senior Software Engineer & System Architect">
	<main class="max-w-6xl mx-auto px-6 pt-32 pb-20">
		<!-- Hero Section -->
		<section id="about" class="mb-32 relative">
			<div class="max-w-3xl">
				<span class="inline-block px-3 py-1 rounded-full bg-blue-500/10 text-blue-400 text-xs font-bold tracking-wider uppercase mb-6 border border-blue-500/20">
					Available for architectural consulting
				</span>
				<h1 class="text-5xl md:text-7xl font-extrabold mb-8 leading-[1.1]">
					Building <span class="text-gradient">Scalable Systems</span> for the modern web.
				</h1>
				<p class="text-slate-400 text-xl md:text-2xl leading-relaxed mb-10 max-w-2xl">
					I'm Sreejith, a Senior Software Engineer specializing in Java architecture, 
					high-concurrency systems, and cloud-native scalability.
				</p>
				<div class="flex flex-wrap gap-4">
					<a href="#writing" class="px-8 py-4 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-bold transition-all hover:scale-105 shadow-lg shadow-blue-500/20">
						Read Case Studies
					</a>
					<a href="https://linkedin.com" target="_blank" class="px-8 py-4 rounded-xl glass-card hover:bg-white/10 font-bold transition-all">
						LinkedIn Profile
					</a>
				</div>
			</div>
		</section>

		<!-- Skills Section -->
		<section id="skills" class="mb-32">
			<h2 class="text-3xl font-bold mb-12 flex items-center gap-4">
				Core Expertise
				<div class="h-px flex-1 bg-white/10"></div>
			</h2>
			<div class="grid md:grid-cols-3 gap-8">
				{skills.map(skill => (
					<div class="glass-card p-8 hover:border-white/20 transition-colors group">
						<h3 class="text-blue-400 font-bold mb-6 text-lg uppercase tracking-widest">{skill.category}</h3>
						<ul class="space-y-4">
							{skill.items.map(item => (
								<li class="flex items-center gap-3 text-slate-300">
									<div class="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_8px_rgba(52,211,153,0.5)]"></div>
									{item}
								</li>
							))}
						</ul>
					</div>
				))}
			</div>
		</section>

		<!-- Featured Writing -->
		<section id="writing">
			<div class="flex justify-between items-end mb-12">
				<div>
					<h2 class="text-3xl font-bold mb-4">Latest System Design Posts</h2>
					<p class="text-slate-400">Deep dives into architecture, performance, and scaling strategies.</p>
				</div>
				<a href="#" class="text-blue-400 hover:text-blue-300 font-medium hidden md:block">View all posts →</a>
			</div>
			
			<div class="grid md:grid-cols-2 gap-8">
				{sortedPosts.map(post => (
					<article class="glass-card p-8 hover:bg-white/[0.03] transition-all hover:-translate-y-1 group relative overflow-hidden">
						<!-- Hover Glow Effect -->
						<div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-emerald-500/5 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
						
						<div class="flex justify-between items-start mb-6">
							<span class={`px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-tighter ${
								post.data.complexity === 'Easy' ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' :
								post.data.complexity === 'Medium' ? 'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20' :
								'bg-red-500/10 text-red-400 border border-red-500/20'
							}`}>
								{post.data.complexity} Complexity
							</span>
							<time class="text-slate-500 text-xs font-medium">
								{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
							</time>
						</div>

						<h3 class="text-2xl font-bold mb-4 group-hover:text-blue-400 transition-colors leading-tight">
							<a href={`${import.meta.env.BASE_URL}/system-design/${post.id}`}>
								{post.data.title}
							</a>
						</h3>
						
						<p class="text-slate-400 mb-8 line-clamp-2 leading-relaxed">
							{post.data.description}
						</p>

						<div class="flex flex-wrap gap-2 mt-auto">
							{post.data.tags.map(tag => (
								<span class="text-[10px] font-bold uppercase tracking-widest bg-slate-800 text-slate-300 px-3 py-1 rounded-md border border-white/5">
									#{tag}
								</span>
							))}
						</div>
					</article>
				))}
			</div>
		</section>
	</main>
</Layout>
