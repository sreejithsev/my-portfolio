---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const categories = [
	{ name: 'Java & Spring', icon: '☕', description: 'Deep dives into JVM, Spring Boot, and Security.' },
	{ name: 'Architecture', icon: '🏗️', description: 'System design, Microservices, and Event-Driven patterns.' },
	{ name: 'Cloud & Infrastructure', icon: '☁️', description: 'Azure, GCP, Kubernetes, and API Management.' },
	{ name: 'DevOps & Tooling', icon: '🛠️', description: 'CI/CD, GitHub Actions, and Linux systems.' }
];

const expertise = [
	{ label: "Languages", value: "Java (Expert), Spring Ecosystem, Node.js" },
	{ label: "Architecture", value: "Event-Driven (Kafka), REST, GraphQL, Microservices" },
	{ label: "Persistence", value: "MySQL, PostgreSQL, MongoDB" },
	{ label: "Cloud/Infra", value: "Azure, GCP, Nginx, Tomcat, AlmaLinux" }
];
---

<Layout title="Engineering Bytes | Software Engineer & Tech Enthusiast">
	<main class="max-w-6xl mx-auto px-6 pt-32 pb-20">
		<!-- Hero / Manifest Section -->
		<section id="about" class="mb-32">
			<div class="grid lg:grid-cols-[1.5fr_1fr] gap-12 items-start">
				<div>
					<h1 class="text-4xl md:text-6xl font-extrabold mb-6 text-white tracking-tight">
						Software Engineer & <br/>
						<span class="text-blue-400">Tech Enthusiast</span>
					</h1>
					<p class="text-slate-400 text-lg md:text-xl leading-relaxed mb-8 max-w-2xl">
						I solve real-world problems through robust, scalable technology. 
						My passion lies in deconstructing complex distributed systems into 
						simple, digestible "bytes" of knowledge.
					</p>
					<div class="flex gap-4">
						<a href="#hub" class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-mono text-xs font-bold uppercase tracking-widest rounded-lg transition-all">
							Explore Hub
						</a>
						<a href="https://linkedin.com" target="_blank" class="px-6 py-3 border border-white/10 hover:bg-white/5 text-slate-300 font-mono text-xs font-bold uppercase tracking-widest rounded-lg transition-all">
							LinkedIn
						</a>
					</div>
				</div>

				<!-- Technical Manifest Card -->
				<div class="blueprint-card p-6 font-mono text-sm relative overflow-hidden group">
					<div class="absolute top-0 right-0 p-4 text-[10px] text-slate-600 uppercase font-bold tracking-tighter">System.Manifest</div>
					<div class="space-y-6">
						{expertise.map(item => (
							<div>
								<div class="text-blue-400/60 text-[10px] font-bold uppercase mb-1 tracking-widest">{item.label}</div>
								<div class="text-slate-300 border-l-2 border-blue-500/20 pl-3 py-1 bg-blue-500/[0.02]">
									{item.value}
								</div>
							</div>
						))}
					</div>
					<div class="mt-8 pt-6 border-t border-white/5 flex justify-between items-center">
						<div class="flex gap-2">
							<div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
							<span class="text-[10px] text-slate-500 uppercase font-bold">Status: Online</span>
						</div>
						<div class="text-[10px] text-slate-600">v2.1.0-stable</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Knowledge Hub Categories -->
		<section id="hub" class="mb-32 scroll-mt-24">
			<div class="flex items-center gap-4 mb-12">
				<h2 class="text-2xl font-bold text-white uppercase tracking-widest font-mono text-sm">Knowledge Hub</h2>
				<div class="h-px flex-1 bg-white/5"></div>
			</div>
			<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
				{categories.map(cat => (
					<div class="blueprint-card p-6 hover:border-blue-500/30 transition-all group">
						<div class="text-3xl mb-4 grayscale group-hover:grayscale-0 transition-all">{cat.icon}</div>
						<h3 class="text-white font-bold mb-2 font-mono text-sm uppercase tracking-tight">{cat.name}</h3>
						<p class="text-slate-500 text-xs leading-relaxed">{cat.description}</p>
					</div>
				))}
			</div>
		</section>

		<!-- Latest Bytes (Posts) -->
		<section id="writing">
			<div class="flex justify-between items-end mb-12">
				<h2 class="text-2xl font-bold text-white uppercase tracking-widest font-mono text-sm">Latest Bytes</h2>
				<a href="#" class="text-xs font-mono font-bold text-blue-500 hover:text-blue-400 uppercase tracking-widest">Archive // 01</a>
			</div>
			
			<div class="grid gap-6">
				{sortedPosts.map(post => (
					<article class="blueprint-card p-6 md:p-8 hover:bg-white/[0.02] transition-all group">
						<div class="flex flex-col md:flex-row md:items-center gap-6">
							<div class="flex-1">
								<div class="flex items-center gap-3 mb-4">
									<span class="text-[10px] font-mono font-bold text-blue-500 bg-blue-500/10 px-2 py-0.5 rounded border border-blue-500/20 uppercase">
										{post.data.category}
									</span>
									<span class="text-slate-700 font-mono text-xs">//</span>
									<time class="text-slate-500 font-mono text-[10px] uppercase">
										{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
									</time>
								</div>
								<h3 class="text-xl md:text-2xl font-bold text-white mb-3 group-hover:text-blue-400 transition-colors">
									<a href={`${import.meta.env.BASE_URL}/posts/${post.id}`}>
										{post.data.title}
									</a>
								</h3>
								<p class="text-slate-500 text-sm leading-relaxed line-clamp-2 max-w-3xl">
									{post.data.description}
								</p>
							</div>
							<div class="flex md:flex-col items-center md:items-end gap-4 md:gap-2">
								<span class={`text-[9px] font-mono font-bold px-2 py-1 rounded border ${
									post.data.complexity === 'Easy' ? 'border-emerald-500/20 text-emerald-500 bg-emerald-500/5' :
									post.data.complexity === 'Medium' ? 'border-yellow-500/20 text-yellow-500 bg-yellow-500/5' :
									'border-red-500/20 text-red-500 bg-red-500/5'
								}`}>
									{post.data.complexity}
								</span>
								<div class="hidden md:flex gap-2">
									{post.data.tags.slice(0, 2).map(tag => (
										<span class="text-[9px] font-mono text-slate-600 uppercase">#{tag}</span>
									))}
								</div>
							</div>
						</div>
					</article>
				))}
			</div>
		</section>
	</main>
</Layout>
