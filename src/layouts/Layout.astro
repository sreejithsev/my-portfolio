---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Software Engineer & Tech Enthusiast" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg`} />
		<link rel="icon" href={`${baseUrl}/favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- Google Fonts: Inter & JetBrains Mono -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#020617] text-slate-300 antialiased selection:bg-blue-500/30">
		<!-- Blueprint Dot Grid -->
		<div class="fixed inset-0 -z-10 pointer-events-none" 
			 style="background-image: radial-gradient(#ffffff0a 1px, transparent 1px); background-size: 24px 24px;">
		</div>

		<!-- Navigation -->
		<header class="fixed top-0 w-full z-50 border-b border-white/5 bg-[#020617]/80 backdrop-blur-md">
			<nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
				<a href={`${baseUrl}/`} class="flex items-center gap-2 group">
					<div class="w-8 h-8 bg-blue-600 rounded flex items-center justify-center font-mono font-bold text-white group-hover:bg-blue-500 transition-colors">EB</div>
					<span class="text-lg font-bold tracking-tight text-white group-hover:text-blue-400 transition-colors">Engineering Bytes</span>
				</a>
				<div class="hidden md:flex gap-8 text-xs font-bold uppercase tracking-widest font-mono text-slate-500">
					<a href={`${baseUrl}/#about`} class="hover:text-white transition-colors">About</a>
					<a href={`${baseUrl}/#hub`} class="hover:text-white transition-colors">Knowledge Hub</a>
				</div>
				<div class="flex items-center gap-4">
					<a href="https://github.com" target="_blank" class="p-2 text-slate-500 hover:text-white transition-colors">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
					</a>
				</div>
			</nav>
		</header>

		<slot />

		<footer class="border-t border-white/5 bg-black/20 py-12 mt-20">
			<div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
				<div class="flex items-center gap-2">
					<div class="w-6 h-6 bg-slate-800 rounded flex items-center justify-center font-mono text-[10px] font-bold text-slate-400">EB</div>
					<p class="text-slate-500 text-xs font-mono">
						&copy; {new Date().getFullYear()} Engineering Bytes.
					</p>
				</div>
				<div class="flex gap-8 text-slate-500 text-xs font-mono uppercase tracking-widest">
					<a href="#" class="hover:text-white transition-colors">LinkedIn</a>
					<a href="#" class="hover:text-white transition-colors">Medium</a>
				</div>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--font-inter: 'Inter', sans-serif;
		--font-mono: 'JetBrains Mono', monospace;
	}
	
	body {
		font-family: var(--font-inter);
	}

	pre, code, .font-mono {
		font-family: var(--font-mono);
	}

	.blueprint-card {
		@apply bg-slate-900/40 border border-white/5 rounded-xl;
	}

	.text-blue-glow {
		@apply text-blue-400 drop-shadow-[0_0_8px_rgba(96,165,250,0.4)];
	}

	::-webkit-scrollbar {
		width: 8px;
	}
	::-webkit-scrollbar-track {
		@apply bg-[#020617];
	}
	::-webkit-scrollbar-thumb {
		@apply bg-slate-800 rounded-full hover:bg-slate-700 transition-colors;
	}
</style>